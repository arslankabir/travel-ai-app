# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/travel_db
VECTOR_DIMENSION=512

# Deploy (Supabase) — use only for one-time ingest, not Railway:
# SUPABASE_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.unrkkzzmeumoogivclpv.supabase.co:5432/postgres
#
# Railway API — use Session pooler (IPv4), copy from Supabase Connect UI:
# DATABASE_URL=postgresql://postgres.unrkkzzmeumoogivclpv:YOUR_PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# ==============================================================================
# EMBEDDING CONFIGURATION (Fixed — OpenAI only, never pluggable)
# ==============================================================================
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=your_openai_key_here

# ==============================================================================
# CHAT LLM CONFIGURATION (Pluggable — Ollama local or OpenAI-compatible API)
# ==============================================================================
#
# LLM_PROVIDER=openai means "OpenAI-compatible HTTP chat API", NOT necessarily OpenAI Inc.
# Set LLM_BASE_URL + LLM_API_KEY to use: DeepSeek, Groq, Mistral, Together, OpenAI, etc.
# Embeddings always use OPENAI_API_KEY above — never LLM_API_KEY.
#
# Providers with a native non-OpenAI SDK (e.g. Anthropic Claude direct) need a factory branch.
#
# Option A: Local chat agents (Ollama on host machine)
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_INTENT=qwen2.5:3b
LLM_MODEL_REVIEW=qwen2.5:3b
LLM_MODEL_ITINERARY=llama3.1:8b

# Option B: Production chat — any OpenAI-compatible API (OpenAI, Groq, Mistral, …)
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...                    # chat only (or omit to reuse OPENAI_API_KEY)
# LLM_MODEL_INTENT=gpt-4o-mini
# LLM_MODEL_REVIEW=gpt-4o-mini
# LLM_MODEL_ITINERARY=gpt-4o

# Option C: Production chat — DeepSeek example (same openai provider + different base URL)
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL_INTENT=deepseek-chat
# LLM_MODEL_REVIEW=deepseek-chat
# LLM_MODEL_ITINERARY=deepseek-reasoner

# ==============================================================================
# REDIS (optional cache — started via docker compose)
# ==============================================================================
REDIS_URL=redis://localhost:6379/0

# ==============================================================================
# INGESTION
# ==============================================================================
CALENDAR_WINDOW_DAYS=90
EMBED_BATCH_SIZE=100
REVIEWS_PER_LISTING=5

# ==============================================================================
# BACKEND / FRONTEND (Phase 2)
# ==============================================================================
CORS_ORIGINS=http://localhost:3000
# Frontend: copy to frontend/.env.local
# NEXT_PUBLIC_API_URL=http://localhost:8000
